---
// src/pages/about.astro
import Base from '../layouts/Base.astro';
const WHATSAPP = 'https://wa.me/573000000000';
---
<Base title="About" description="The story, philosophy, and sourcing principles behind Velvet Greens.">

  <!-- HERO -->
  <section class="about-hero">
    <div class="container">
      <p class="section-label fade-up fade-up-1">Our Story</p>
      <h1 class="about-title fade-up fade-up-2">We believe nature<br/><em>holds the answer.</em></h1>
    </div>
  </section>

  <!-- BRAND STORY -->
  <section class="about-section">
    <div class="container about-grid">
      <div class="about-visual">
        <div class="about-img-wrap">
          <img src="/media/about.jpg" alt="Velvet Greens sourcing" loading="lazy" />
        </div>
      </div>
      <div class="about-text fade-up">
        <p class="section-label">Brand Story</p>
        <h2 class="section-title">Where it begins</h2>
        <div class="divider"></div>
        <p>
          Velvet Greens was born from a deep respect for botanical tradition and a desire
          to make high-quality functional ingredients accessible to everyone. We saw a gap
          between ancient plant wisdom and the modern consumer — and decided to bridge it.
        </p>
        <p style="margin-top: 16px;">
          Every ingredient we carry has been carefully selected for its potency, safety, and
          traceability. We work directly with trusted suppliers to ensure that what reaches you
          is as close to its natural state as possible.
        </p>
      </div>
    </div>
  </section>

  <!-- PHILOSOPHY -->
  <section class="about-philosophy">
    <div class="container">
      <div class="philosophy-header">
        <p class="section-label">Our Philosophy</p>
        <h2 class="section-title">Three principles that guide us</h2>
        <div class="divider"></div>
      </div>
      <div class="pillars-grid">
        <div class="pillar fade-up fade-up-1">
          <div class="pillar-icon">01</div>
          <h3>Purity</h3>
          <p>
            No fillers, no additives. Every product is as close to nature as it can be —
            clean, honest, and effective.
          </p>
        </div>
        <div class="pillar fade-up fade-up-2">
          <div class="pillar-icon">02</div>
          <h3>Traceability</h3>
          <p>
            We know exactly where each ingredient comes from. Sourcing transparency
            is not optional for us — it's foundational.
          </p>
        </div>
        <div class="pillar fade-up fade-up-3">
          <div class="pillar-icon">03</div>
          <h3>Functional Value</h3>
          <p>
            Every ingredient we carry has documented traditional use or emerging scientific
            support. We don't sell trends. We sell results.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SOURCING -->
  <section class="about-sourcing">
    <div class="container about-grid reverse">
      <div class="about-text fade-up">
        <p class="section-label">Sourcing</p>
        <h2 class="section-title">Thoughtful at every step</h2>
        <div class="divider"></div>
        <p>
          We source directly from regions where each plant thrives naturally — Mucuna Pruriens
          from tropical climates, Jabuticaba from Brazilian farms, Goji Berries from verified
          Asian growers. Proximity to origin means better quality, better pricing, and a
          more direct relationship with the land.
        </p>
        <p style="margin-top: 16px;">
          We prioritize small, family-run producers who share our values and whose practices
          align with environmental stewardship.
        </p>
      </div>
      <div class="about-visual">
        <div class="about-img-wrap">
          <img src="/media/sourcing.jpg" alt="Sourcing principles" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="about-cta">
    <div class="container">
      <h2>Ready to explore?</h2>
      <p>Browse our ingredient collection or reach out directly.</p>
      <div class="about-cta-btns">
        <a href="/ingredients" class="btn btn-primary">Explore Ingredients</a>
        <a href={WHATSAPP} target="_blank" rel="noopener" class="btn btn-outline wa-outline">Chat on WhatsApp</a>
      </div>
    </div>
  </section>

</Base>

<style>
  /* HERO */
  .about-hero {
    background: var(--color-primary);
    padding: 100px 0 72px;
    position: relative;
    overflow: hidden;
  }
  .about-hero::after {
    content: '';
    position: absolute;
    right: -10%;
    top: -10%;
    width: 60%;
    height: 120%;
    background: radial-gradient(circle, rgba(106,143,123,0.15) 0%, transparent 70%);
    pointer-events: none;
  }
  .about-title {
    font-size: clamp(2.5rem, 5.5vw, 4.5rem);
    color: var(--color-white);
    line-height: 1.1;
    max-width: 700px;
  }
  .about-title em { color: var(--color-accent); font-style: italic; }

  /* SHARED SECTION */
  .about-section,
  .about-sourcing { padding: var(--section-py) 0; }
  .about-sourcing { background: var(--color-white); }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  .about-grid.reverse > *:first-child { order: 2; }
  .about-grid.reverse > *:last-child { order: 1; }

  .about-img-wrap {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4/5;
    background: var(--color-border);
  }
  .about-img-wrap img { width: 100%; height: 100%; object-fit: cover; }
  .about-text p { color: var(--color-muted); line-height: 1.8; }

  /* PHILOSOPHY */
  .about-philosophy { padding: var(--section-py) 0; background: var(--color-bg); }
  .philosophy-header { margin-bottom: 56px; }
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }
  .pillar {
    padding: 36px;
    background: var(--color-white);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .pillar:hover { transform: translateY(-6px); box-shadow: var(--shadow-md); }
  .pillar-icon {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    color: var(--color-accent);
    opacity: 0.6;
    margin-bottom: 16px;
    line-height: 1;
  }
  .pillar h3 { font-size: 1.2rem; color: var(--color-primary); margin-bottom: 12px; }
  .pillar p { font-size: 0.9rem; color: var(--color-muted); line-height: 1.7; }

  /* CTA */
  .about-cta {
    padding: 96px 0;
    background: var(--color-primary);
    text-align: center;
  }
  .about-cta h2 { font-size: clamp(1.8rem, 4vw, 3rem); color: var(--color-white); margin-bottom: 12px; }
  .about-cta p { color: rgba(255,255,255,0.55); margin-bottom: 36px; font-size: 1rem; }
  .about-cta-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .wa-outline { color: var(--color-white); border-color: rgba(255,255,255,0.35); }

  @media (max-width: 960px) {
    .about-grid { grid-template-columns: 1fr; gap: 40px; }
    .about-grid.reverse > * { order: unset; }
    .about-img-wrap { aspect-ratio: 16/9; }
    .pillars-grid { grid-template-columns: 1fr; }
  }
</style>
