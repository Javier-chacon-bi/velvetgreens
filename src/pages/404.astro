---
// src/pages/404.astro
import Base from '../layouts/Base.astro';
---
<Base title="404 — Not Found">
  <section style="min-height:70vh;display:flex;align-items:center;background:var(--color-primary);">
    <div class="container" style="text-align:center;padding-block:80px;">
      <p class="section-label" style="margin-bottom:16px;">Error 404</p>
      <h1 style="font-size:clamp(3rem,8vw,6rem);color:var(--color-white);margin-bottom:16px;">
        Lost in<br/><em style="color:var(--color-accent);font-style:italic;-webkit-text-stroke:1px white;paint-order:stroke fill;">the wild.</em>
      </h1>
      <p style="color:rgba(255,255,255,0.5);font-size:1.05rem;margin-bottom:40px;">
        This page doesn't exist — but great ingredients do.
      </p>
      <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
        <a href="/" class="btn btn-accent">Go Home</a>
        <a href="/ingredients" class="btn btn-outline" style="color:white;border-color:rgba(255,255,255,0.35);">Browse Ingredients</a>
      </div>
    </div>
  </section>
</Base>
