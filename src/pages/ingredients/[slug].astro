---
// src/pages/ingredients/[slug].astro
// Because we use output: 'static', this page is a client-rendered shell.
// The actual data is fetched client-side via JS from the Cloudflare Worker.
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const API = import.meta.env.PUBLIC_API_BASE || 'https://api.velvetgreens.com';
  try {
    const res = await fetch(`${API}/api/ingredients`);
    const ingredients = await res.json();
    return (Array.isArray(ingredients) ? ingredients : []).map(ing => ({ params: { slug: ing.slug } }));
  } catch {
    return [];
  }
}

const { slug } = Astro.params;
---
<Base title="Ingredient" description="Learn about this premium botanical ingredient.">

  <!-- Loading shell -->
  <div id="page-shell">

    <!-- Hero -->
    <section class="ing-hero" id="ing-hero">
      <div class="container ing-hero-inner">
        <div class="ing-hero-text">
          <a href="/ingredients" class="back-link">← All Ingredients</a>
          <div class="ing-hero-meta skeleton" style="height:14px;width:100px;margin-bottom:12px"></div>
          <h1 class="ing-title" id="ing-title">
            <div class="skeleton" style="height:56px;width:70%;margin-bottom:12px"></div>
          </h1>
          <div class="skeleton" style="height:20px;width:60%;margin-bottom:24px"></div>
          <div class="skeleton" style="height:40px;width:180px;border-radius:999px"></div>
        </div>
        <div class="ing-hero-img">
          <div class="skeleton" style="height:100%;min-height:400px;border-radius:var(--radius-lg)"></div>
        </div>
      </div>
    </section>

    <!-- Content -->
    <section class="ing-content section-featured">
      <div class="container ing-grid">
        <div class="ing-main" id="ing-main">
          <div class="skeleton" style="height:300px;border-radius:var(--radius-md)"></div>
        </div>
        <aside class="ing-sidebar" id="ing-sidebar">
          <div class="skeleton" style="height:220px;border-radius:var(--radius-md)"></div>
        </aside>
      </div>
    </section>

  </div>

  <!-- Recipes section (populated after load) -->
  <section class="ing-recipes" id="ing-recipes" style="display:none">
    <div class="container">
      <p class="section-label">From our kitchen</p>
      <h2 class="section-title">Related Recipes</h2>
      <div class="divider"></div>
      <div class="recipes-grid" id="related-recipes-grid"></div>
    </div>
  </section>

</Base>

<style>
  /* HERO */
  .ing-hero {
    background: var(--color-primary);
    padding: 80px 0 64px;
  }
  .ing-hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .back-link {
    display: inline-block;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-secondary);
    margin-bottom: 24px;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--color-accent); }
  .ing-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: var(--color-white);
    margin-bottom: 12px;
  }
  .ing-subtitle {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.55);
    margin-bottom: 32px;
  }
  .ing-hero-img {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 1;
    background: rgba(255,255,255,0.05);
  }
  .ing-hero-img img { width: 100%; height: 100%; object-fit: cover; }

  /* CONTENT */
  .ing-content { padding: 72px 0 var(--section-py); }
  .ing-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 64px;
    align-items: start;
  }

  /* Main content blocks */
  .content-section { margin-bottom: 48px; }
  .content-section h2 {
    font-size: 1.5rem;
    color: var(--color-primary);
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-border);
  }
  .content-section p { color: var(--color-muted); line-height: 1.8; }
  .benefits-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .benefits-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.95rem;
    color: var(--color-text);
  }
  .benefits-list li::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    margin-top: 8px;
    flex-shrink: 0;
  }
  .usage-list {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 4px;
  }
  .usage-pill {
    padding: 7px 16px;
    border-radius: var(--radius-pill);
    border: 1px solid var(--color-border);
    font-size: 0.8rem;
    color: var(--color-secondary);
    font-weight: 500;
  }

  /* Sidebar */
  .sidebar-card {
    background: var(--color-white);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    padding: 28px;
    margin-bottom: 24px;
  }
  .sidebar-card h3 {
    font-size: 1rem;
    color: var(--color-primary);
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--color-border);
  }
  .sidebar-wa {
    background: var(--color-primary);
    border-radius: var(--radius-md);
    padding: 28px;
    color: white;
  }
  .sidebar-wa h3 { font-size: 1.1rem; margin-bottom: 8px; color: white; }
  .sidebar-wa p { font-size: 0.85rem; opacity: 0.6; margin-bottom: 20px; }

  /* Related recipes */
  .ing-recipes { padding: var(--section-py) 0; background: var(--color-white); }
  .recipes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-top: 32px;
  }
  .recipe-card .card-img { width: 100%; aspect-ratio: 16/9; object-fit: cover; }
  .recipe-card .card-body { padding: 20px; }
  .recipe-card .card-body h3 { font-size: 1rem; margin-bottom: 6px; }
  .recipe-card .card-body p { font-size: 0.85rem; color: var(--color-muted); }

  @media (max-width: 960px) {
    .ing-hero-inner { grid-template-columns: 1fr; }
    .ing-hero-img { aspect-ratio: 16/9; }
    .ing-grid { grid-template-columns: 1fr; }
    .recipes-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) { .recipes-grid { grid-template-columns: 1fr; } }
</style>

<script>
  const API = import.meta.env.PUBLIC_API_BASE || 'https://api.velvetgreens.com';
  const WHATSAPP = 'https://wa.me/573000000000';
  const slug = window.location.pathname.split('/').filter(Boolean).pop();

  async function loadIngredient() {
    try {
      const res = await fetch(`${API}/api/ingredients/${slug}`);
      if (!res.ok) { window.location.href = '/ingredients'; return; }
      const ing = await res.json();

      // Update page title
      document.title = `${ing.name} — Velvet Greens`;

      // Hero
      document.getElementById('ing-hero').innerHTML = `
        <div class="container ing-hero-inner">
          <div class="ing-hero-text fade-up">
            <a href="/ingredients" class="back-link">← All Ingredients</a>
            <h1 class="ing-title">${ing.name}</h1>
            <p class="ing-subtitle">${ing.subtitle || ing.description || ''}</p>
            <a href="${WHATSAPP}" target="_blank" rel="noopener" class="btn btn-accent">
              Order via WhatsApp
            </a>
          </div>
          <div class="ing-hero-img fade-up fade-up-2">
            <img src="${ing.image_url || '/media/ingredient_1.jpg'}" alt="${ing.name}" />
          </div>
        </div>
      `;

      // Main content
      const benefits = Array.isArray(ing.benefits) ? ing.benefits : [];
      const usage = Array.isArray(ing.usage) ? ing.usage : typeof ing.usage === 'string' ? [ing.usage] : [];

      document.getElementById('ing-main').innerHTML = `
        <div class="content-section fade-up">
          <h2>Overview</h2>
          <p>${ing.description || ''}</p>
        </div>
        ${benefits.length ? `
        <div class="content-section fade-up fade-up-2">
          <h2>Key Benefits</h2>
          <ul class="benefits-list">
            ${benefits.map(b => `<li>${b}</li>`).join('')}
          </ul>
        </div>` : ''}
        ${ing.traditional_uses ? `
        <div class="content-section fade-up fade-up-3">
          <h2>Traditional Uses</h2>
          <p>${ing.traditional_uses}</p>
        </div>` : ''}
        ${usage.length ? `
        <div class="content-section fade-up fade-up-4">
          <h2>How to Use</h2>
          <div class="usage-list">
            ${usage.map(u => `<span class="usage-pill">${u}</span>`).join('')}
          </div>
        </div>` : ''}
      `;

      // Sidebar
      document.getElementById('ing-sidebar').innerHTML = `
        <div class="sidebar-card">
          <h3>Quick Info</h3>
          ${ing.origin ? `<p><strong>Origin:</strong> ${ing.origin}</p>` : ''}
          ${ing.category ? `<p style="margin-top:8px"><strong>Category:</strong> ${ing.category}</p>` : ''}
        </div>
        <div class="sidebar-wa">
          <h3>Interested?</h3>
          <p>Contact us directly to place an order or ask questions.</p>
          <a href="${WHATSAPP}" target="_blank" rel="noopener" class="btn btn-accent" style="width:100%;justify-content:center">
            Chat on WhatsApp
          </a>
        </div>
      `;

      // Load related recipes
      loadRelatedRecipes(ing.id || slug);

    } catch (e) {
      console.error('Failed to load ingredient', e);
    }
  }

  async function loadRelatedRecipes(ingredientId) {
    try {
      const res = await fetch(`${API}/api/recipes?ingredient=${ingredientId}`);
      const recipes = await res.json();
      if (!recipes || recipes.length === 0) return;

      const section = document.getElementById('ing-recipes');
      const grid = document.getElementById('related-recipes-grid');
      if (!section || !grid) return;

      grid.innerHTML = recipes.slice(0, 3).map(r => `
        <a href="/recipes/${r.slug}" class="card recipe-card" style="display:block;color:inherit;">
          <img class="card-img" src="${r.image_url || '/media/recipe_1.png'}" alt="${r.name}" loading="lazy" />
          <div class="card-body">
            <h3>${r.name}</h3>
            <p>${r.description || ''}</p>
          </div>
        </a>
      `).join('');
      section.style.display = 'block';
    } catch (e) {
      // Related recipes are optional
    }
  }

  loadIngredient();
</script>
