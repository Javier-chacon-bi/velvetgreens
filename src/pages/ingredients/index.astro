---
// src/pages/ingredients/index.astro
import Base from '../../layouts/Base.astro';
---
<Base title="Ingredients" description="Premium botanical ingredients sourced for purity and functional value.">

  <section class="page-hero">
    <div class="container">
      <p class="section-label fade-up fade-up-1">Our Collection</p>
      <h1 class="page-title fade-up fade-up-2">Ingredients</h1>
      <p class="page-subtitle fade-up fade-up-3">
        Botanicals selected for potency, purity, and traceability.
      </p>
    </div>
  </section>

  <section class="section-list">
    <div class="container">
      <!-- Filters (UI only — future API integration) -->
      <div class="filter-bar" id="filter-bar">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="energy">Energy</button>
        <button class="filter-btn" data-filter="antioxidants">Antioxidants</button>
        <button class="filter-btn" data-filter="adaptogens">Adaptogens</button>
      </div>

      <!-- Grid populated by JS -->
      <div class="ingredients-grid" id="ingredients-grid">
        <!-- Skeletons -->
        {Array.from({length: 6}).map(() => (
          <div class="card ingredient-card skeleton-card">
            <div class="skeleton" style="height:240px"></div>
            <div class="card-body">
              <div class="skeleton" style="height:20px;width:60%;margin-bottom:8px"></div>
              <div class="skeleton" style="height:13px;width:90%;margin-bottom:5px"></div>
              <div class="skeleton" style="height:13px;width:75%"></div>
            </div>
          </div>
        ))}
      </div>

      <div id="empty-state" class="empty-state" style="display:none">
        <p>No ingredients found. Check back soon.</p>
      </div>
    </div>
  </section>

</Base>

<style>
  .page-hero {
    padding: 96px 0 64px;
    background: var(--color-primary);
  }
  .page-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--color-white);
    margin-bottom: 16px;
  }
  .page-hero .section-label { margin-bottom: 12px; }
  .page-subtitle {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.55);
    max-width: 480px;
  }

  .section-list { padding: 72px 0 var(--section-py); }

  .filter-bar {
    display: flex;
    gap: 10px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }
  .filter-btn {
    padding: 9px 22px;
    border-radius: var(--radius-pill);
    border: 1.5px solid var(--color-border);
    background: transparent;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    cursor: pointer;
    color: var(--color-muted);
    transition: all 0.2s;
  }
  .filter-btn:hover { border-color: var(--color-secondary); color: var(--color-secondary); }
  .filter-btn.active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-white);
  }

  .ingredients-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  .ingredient-card .card-img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
  }
  .ingredient-card .card-body { padding: 24px; }
  .ingredient-card .card-body h3 {
    font-size: 1.2rem;
    color: var(--color-primary);
    margin-bottom: 8px;
  }
  .ingredient-card .card-body p {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-bottom: 16px;
  }
  .ingredient-card .card-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .tag {
    padding: 3px 10px;
    border-radius: var(--radius-pill);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: rgba(106,143,123,0.12);
    color: var(--color-secondary);
  }
  .card-link {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-secondary);
    transition: color 0.2s;
  }
  .card-link:hover { color: var(--color-accent); -webkit-text-stroke: 1px white; paint-order: stroke fill; }

  .empty-state {
    text-align: center;
    padding: 80px 0;
    color: var(--color-muted);
    font-size: 1rem;
  }

  @media (max-width: 960px) { .ingredients-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 580px) { .ingredients-grid { grid-template-columns: 1fr; } }
</style>

<script>
  const API = import.meta.env.PUBLIC_API_BASE || 'https://api.velvetgreens.com';

  async function loadIngredients() {
    try {
      const res = await fetch(`${API}/api/ingredients`);
      const data = await res.json();
      const grid = document.getElementById('ingredients-grid');
      const empty = document.getElementById('empty-state');
      if (!grid) return;

      if (!data || data.length === 0) {
        grid.style.display = 'none';
        if (empty) empty.style.display = 'block';
        return;
      }

      grid.innerHTML = data.map((ing, i) => `
        <a href="/ingredients/${ing.slug}" class="card ingredient-card fade-up" style="display:block;color:inherit;animation-delay:${i * 0.08}s">
          <img class="card-img" src="${ing.image_url || `/media/ingredient_${(i % 3) + 1}.jpg`}" alt="${ing.name}" loading="lazy" />
          <div class="card-body">
            <h3>${ing.name}</h3>
            <p>${ing.description || ''}</p>
            ${ing.tags ? `<div class="card-tags">${ing.tags.map(t => `<span class="tag">${t}</span>`).join('')}</div>` : ''}
            <span class="card-link">Learn More →</span>
          </div>
        </a>
      `).join('');
    } catch (e) {
      console.error('Failed to load ingredients', e);
    }
  }

  // Filter UI (visual only — extend with API query params as needed)
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });

  loadIngredients();
</script>
