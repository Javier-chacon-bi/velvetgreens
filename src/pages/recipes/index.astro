---
// src/pages/recipes/index.astro
import Base from '../../layouts/Base.astro';
---
<Base title="Recipes" description="Functional recipes featuring premium botanical ingredients.">

  <section class="page-hero">
    <div class="container">
      <p class="section-label fade-up fade-up-1">From Our Kitchen</p>
      <h1 class="page-title fade-up fade-up-2">Recipes &amp; Uses</h1>
      <p class="page-subtitle fade-up fade-up-3">
        Discover how to integrate premium botanicals into your everyday routine.
      </p>
    </div>
  </section>

  <section class="section-list">
    <div class="container">
      <div class="recipes-grid" id="recipes-grid">
        {Array.from({length: 6}).map(() => (
          <div class="card recipe-card skeleton-card">
            <div class="skeleton" style="height:220px"></div>
            <div class="card-body">
              <div class="skeleton" style="height:18px;width:65%;margin-bottom:8px"></div>
              <div class="skeleton" style="height:13px;width:90%;margin-bottom:5px"></div>
              <div class="skeleton" style="height:13px;width:70%"></div>
            </div>
          </div>
        ))}
      </div>
      <div id="empty-state" class="empty-state" style="display:none">
        <p>No recipes yet. Coming soon.</p>
      </div>
    </div>
  </section>

</Base>

<style>
  .page-hero {
    padding: 96px 0 64px;
    background: var(--color-primary);
  }
  .page-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--color-white);
    margin-bottom: 16px;
  }
  .page-hero .section-label { margin-bottom: 12px; }
  .page-subtitle {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.55);
    max-width: 480px;
  }
  .section-list { padding: 72px 0 var(--section-py); }
  .recipes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .recipe-card .card-img { width: 100%; aspect-ratio: 4/3; object-fit: cover; }
  .recipe-card .card-body { padding: 24px; }
  .recipe-card .card-body h3 { font-size: 1.1rem; color: var(--color-primary); margin-bottom: 8px; }
  .recipe-card .card-body p { font-size: 0.875rem; color: var(--color-muted); margin-bottom: 12px; }
  .recipe-card .card-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 14px; }
  .tag {
    padding: 3px 10px;
    border-radius: var(--radius-pill);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: rgba(106,143,123,0.12);
    color: var(--color-secondary);
  }
  .card-link {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-secondary);
    transition: color 0.2s;
  }
  .card-link:hover { color: var(--color-accent); }
  .empty-state { text-align: center; padding: 80px 0; color: var(--color-muted); }

  @media (max-width: 960px) { .recipes-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 580px) { .recipes-grid { grid-template-columns: 1fr; } }
</style>

<script>
  const API = import.meta.env.PUBLIC_API_BASE || 'https://api.velvetgreens.com';

  async function loadRecipes() {
    try {
      const res = await fetch(`${API}/api/recipes`);
      const data = await res.json();
      const grid = document.getElementById('recipes-grid');
      const empty = document.getElementById('empty-state');
      if (!grid) return;

      if (!data || data.length === 0) {
        grid.style.display = 'none';
        if (empty) empty.style.display = 'block';
        return;
      }

      grid.innerHTML = data.map((r, i) => `
        <a href="/recipes/${r.slug}" class="card recipe-card fade-up" style="display:block;color:inherit;animation-delay:${i * 0.08}s">
          <img class="card-img" src="${r.image_url || `/media/recipe_${(i % 3) + 1}.png`}" alt="${r.name}" loading="lazy" />
          <div class="card-body">
            <h3>${r.name}</h3>
            <p>${r.description || ''}</p>
            ${r.tags ? `<div class="card-tags">${r.tags.map(t => `<span class="tag">${t}</span>`).join('')}</div>` : ''}
            <span class="card-link">View Recipe →</span>
          </div>
        </a>
      `).join('');
    } catch (e) {
      console.error('Failed to load recipes', e);
    }
  }

  loadRecipes();
</script>
