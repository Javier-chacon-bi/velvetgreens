---
// src/pages/recipes/[slug].astro
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const API = import.meta.env.PUBLIC_API_BASE || 'https://api.velvetgreens.com';
  try {
    const res = await fetch(`${API}/api/recipes`);
    const recipes = await res.json();
    return (Array.isArray(recipes) ? recipes : []).map(r => ({ params: { slug: r.slug } }));
  } catch {
    return [];
  }
}
---
<Base title="Recipe" description="A functional recipe from Velvet Greens.">

  <!-- Hero skeleton -->
  <section class="recipe-hero" id="recipe-hero">
    <div class="container">
      <a href="/recipes" class="back-link">← All Recipes</a>
      <div class="skeleton" style="height:48px;width:60%;margin-bottom:12px"></div>
      <div class="skeleton" style="height:20px;width:45%"></div>
    </div>
  </section>

  <!-- Content skeleton -->
  <section class="recipe-body">
    <div class="container recipe-grid">
      <div id="recipe-main">
        <div class="skeleton" style="height:400px;border-radius:var(--radius-lg);margin-bottom:40px"></div>
        <div class="skeleton" style="height:200px;border-radius:var(--radius-md)"></div>
      </div>
      <aside id="recipe-aside">
        <div class="skeleton" style="height:280px;border-radius:var(--radius-md)"></div>
      </aside>
    </div>
  </section>

</Base>

<style>
  .recipe-hero {
    background: var(--color-primary);
    padding: 80px 0 56px;
  }
  .back-link {
    display: inline-block;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-secondary);
    margin-bottom: 24px;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--color-accent); }
  .recipe-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: var(--color-white);
    margin-bottom: 12px;
  }
  .recipe-desc { font-size: 1.05rem; color: rgba(255,255,255,0.55); }

  .recipe-body { padding: 72px 0 var(--section-py); }
  .recipe-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 64px;
    align-items: start;
  }

  /* Hero image */
  .recipe-cover {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    border-radius: var(--radius-lg);
    margin-bottom: 48px;
  }

  /* Steps */
  .steps-section h2 {
    font-size: 1.4rem;
    color: var(--color-primary);
    margin-bottom: 24px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-border);
  }
  .step {
    display: flex;
    gap: 20px;
    margin-bottom: 28px;
    align-items: flex-start;
  }
  .step-num {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 0.9rem;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .step-text { color: var(--color-text); line-height: 1.7; }

  /* Sidebar */
  .sidebar-card {
    background: var(--color-white);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    padding: 28px;
    margin-bottom: 24px;
  }
  .sidebar-card h3 {
    font-size: 1rem;
    color: var(--color-primary);
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--color-border);
  }
  .ing-list { list-style: none; display: flex; flex-direction: column; gap: 8px; }
  .ing-list li {
    font-size: 0.875rem;
    color: var(--color-text);
    padding: 8px 0;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .ing-list li:last-child { border-bottom: none; }
  .ing-list li::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
  }
  .ing-link { color: var(--color-secondary); font-size: 0.75rem; margin-left: auto; }
  .ing-link:hover { color: var(--color-accent); }

  .sidebar-wa { background: var(--color-primary); border-radius: var(--radius-md); padding: 28px; color: white; }
  .sidebar-wa h3 { font-size: 1rem; margin-bottom: 8px; color: white; }
  .sidebar-wa p { font-size: 0.82rem; opacity: 0.6; margin-bottom: 16px; }

  @media (max-width: 960px) { .recipe-grid { grid-template-columns: 1fr; } }
</style>

<script>
  const API = import.meta.env.PUBLIC_API_BASE || 'https://api.velvetgreens.com';
  const WHATSAPP = 'https://wa.me/573000000000';
  const slug = window.location.pathname.split('/').filter(Boolean).pop();

  async function loadRecipe() {
    try {
      const res = await fetch(`${API}/api/recipes/${slug}`);
      if (!res.ok) { window.location.href = '/recipes'; return; }
      const r = await res.json();

      document.title = `${r.name} — Velvet Greens`;

      // Hero
      document.getElementById('recipe-hero').innerHTML = `
        <div class="container fade-up">
          <a href="/recipes" class="back-link">← All Recipes</a>
          <h1 class="recipe-title">${r.name}</h1>
          <p class="recipe-desc">${r.description || ''}</p>
        </div>
      `;

      // Steps
      const steps = Array.isArray(r.steps) ? r.steps : [];
      const ingredients = Array.isArray(r.ingredients) ? r.ingredients : [];

      document.getElementById('recipe-main').innerHTML = `
        <img class="recipe-cover" src="${r.image_url || '/media/recipe_1.png'}" alt="${r.name}" />
        <div class="steps-section fade-up">
          <h2>Preparation</h2>
          ${steps.map((step, i) => `
            <div class="step">
              <div class="step-num">${i + 1}</div>
              <p class="step-text">${typeof step === 'string' ? step : step.text || step}</p>
            </div>
          `).join('')}
        </div>
      `;

      // Sidebar
      document.getElementById('recipe-aside').innerHTML = `
        ${ingredients.length ? `
        <div class="sidebar-card fade-up">
          <h3>Ingredients</h3>
          <ul class="ing-list">
            ${ingredients.map(ing => `
              <li>
                ${typeof ing === 'string' ? ing : ing.name || ing}
                ${ing.slug ? `<a href="/ingredients/${ing.slug}" class="ing-link">View →</a>` : ''}
              </li>
            `).join('')}
          </ul>
        </div>` : ''}
        <div class="sidebar-wa fade-up fade-up-2">
          <h3>Want to order?</h3>
          <p>Ask us about the ingredients used in this recipe.</p>
          <a href="${WHATSAPP}" target="_blank" rel="noopener" class="btn btn-accent" style="width:100%;justify-content:center">
            Chat on WhatsApp
          </a>
        </div>
      `;

    } catch (e) {
      console.error('Failed to load recipe', e);
    }
  }

  loadRecipe();
</script>
